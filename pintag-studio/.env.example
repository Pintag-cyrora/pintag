# Copy to .env.local and fill in real values. .env.local is git-ignored — never commit real credentials.

# Project Settings -> API
SUPABASE_URL=
# Project Settings -> API -> service_role (NOT anon — the pipeline needs this to bypass RLS)
SUPABASE_SERVICE_ROLE_KEY=

# Project Settings -> Database -> Connection string -> URI (used only for applying migrations)
SUPABASE_DB_URL=

# See pipeline/lib/llm.ts — "claude-cli" (default) or "anthropic-api"
LLM_PROVIDER=claude-cli
# Only needed if LLM_PROVIDER=anthropic-api
ANTHROPIC_API_KEY=

# "simulate" (default, no real Meta credentials needed) or "live"
META_PUBLISH_MODE=simulate
